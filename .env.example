# Copy to .env and fill in values:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
CUE_HOST=127.0.0.1
CUE_PORT=8765

# -----------------------------------------------------------------------------
# Mark capture (required for /v1/mark/capture and Linq bookmarks)
# Use the same folder as macOS Cue → Settings → Commands → Mark export folder.
# -----------------------------------------------------------------------------
CUE_MARK_VAULT_ROOT=/Users/you/Documents/Obsidian/YourVault/bookmarks

# Mark LLM — local Ollama (default)
CUE_MARK_LLM_PROVIDER=ollama
CUE_MARK_LLM_BASE_URL=http://localhost:11434
CUE_MARK_LLM_MODEL=gemma4:e4b-mlx
CUE_MARK_LLM_API_KEY=

# Mark LLM — OpenAI (uncomment and set if using cloud instead)
# CUE_MARK_LLM_PROVIDER=openai
# CUE_MARK_LLM_BASE_URL=https://api.openai.com/v1
# CUE_MARK_LLM_MODEL=gpt-4.1-mini
# CUE_MARK_LLM_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Search (/v1/search — used by macOS Cue app)
# -----------------------------------------------------------------------------
CUE_SEARCH_LANCEDB_PATH=~/Library/Application Support/Cue/search/lancedb
CUE_SEARCH_INDEXER_STATE_PATH=~/Library/Application Support/Cue/search/indexer-state.json

CUE_SEARCH_EMBEDDINGS_PROVIDER=ollama
CUE_SEARCH_EMBEDDINGS_BASE_URL=http://localhost:11434
CUE_SEARCH_EMBEDDINGS_MODEL=snowflake-arctic-embed2:latest

# Optional search tuning
# CUE_SEARCH_AGENT_MAX_TURNS=4
# CUE_SEARCH_DEFAULT_MAX_SOURCES=5
# CUE_SEARCH_RETRIEVAL_TOP_K=8

# -----------------------------------------------------------------------------
# Linq iMessage webhook (required for /v1/linq/webhook)
# Get API key from Linq. signing_secret comes from webhook subscription create response.
# -----------------------------------------------------------------------------
CUE_LINQ_API_KEY=
CUE_LINQ_WEBHOOK_SECRET=
CUE_LINQ_ALLOWED_SENDERS=+1XXXXXXXXXX

# Optional Linq settings
# CUE_LINQ_API_BASE_URL=https://api.linqapp.com/api/partner/v3
# CUE_LINQ_JOBS_DB_PATH=~/Library/Application Support/Cue/linq-jobs.sqlite3
# CUE_LINQ_WEBHOOK_MAX_AGE_SECONDS=300
